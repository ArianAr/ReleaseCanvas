<?xml version="1.0" encoding="utf-8"?>
<!--
  Exclude sensitive app data from cloud backup and device transfer (API 31+).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="profile_logo.jpg" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="profile_logo.jpg" />
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
