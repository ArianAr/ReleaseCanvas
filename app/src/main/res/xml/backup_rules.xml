<?xml version="1.0" encoding="utf-8"?>
<!--
  Exclude sensitive app data from Auto Backup (API 23–30 fullBackupContent).
  History, profile, templates, and logo must not leave the device via backup.
-->
<full-backup-content>
    <exclude domain="file" path="datastore/" />
    <exclude domain="file" path="profile_logo.jpg" />
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="root" path="shared_prefs/" />
</full-backup-content>
