    <string name="about_legal_heading">Aviso legal</string>
    <string name="about_legal_body">Las plantillas de cesión son muestras genéricas. No son contratos revisados por abogados, ni formularios oficiales de agencias o plataformas, ni asesoramiento jurídico. Consulta a un abogado antes del uso comercial.</string>
    <string name="about_privacy_heading">Privacidad</string>
    <string name="about_privacy_body">ReleaseCanvas funciona sin conexión para la firma principal. El GPS y la geocodificación opcionales usan ubicación y pueden usar red. Los PDF van a Documents/ReleaseCanvas vía MediaStore. El historial solo está en este dispositivo. Las copias en la nube usan el menú de compartir del sistema (p. ej. Drive, Dropbox) con tu cuenta — no hay sincronización automática ni servidor de ReleaseCanvas.</string>
    <string name="about_license_heading">Licencia</string>
    <string name="about_license_body">ReleaseCanvas es software libre bajo la GNU GPL v3.0. El código está en GitHub: ArianAr/ReleaseCanvas.</string>
